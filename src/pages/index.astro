---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeIsland from '../components/islands/HomeIsland';
---

<BaseLayout
  title="Washer & Dryer Rentals Ocean Springs MS | Sudsy Co."
  description="Rent washers & dryers in Ocean Springs, MS starting at $59.99/mo. Free delivery, no credit checks. Serving Biloxi, Gulfport & the Gulf Coast."
  canonical="https://www.sudsycorentals.com/"
  geoRegion="US-MS"
  geoPlacename="Ocean Springs, Mississippi"
>
  <!-- Static H1 for SEO crawlers (visually hidden, replaced by React) -->
  <h1 class="sr-only">Washer & Dryer Rentals in Ocean Springs, MS</h1>
  <div id="app-loading" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);">
    <div style="text-align: center; color: white;">
      <img src="/logo.png" alt="Sudsy Co." style="width: 200px; margin-bottom: 1rem;" onerror="this.style.display='none'">
      <p style="font-size: 1.25rem; font-weight: 500;">Loading...</p>
    </div>
  </div>
  <HomeIsland client:only="react" />
</BaseLayout>
