import DryerInstallationIsland from '../components/islands/DryerInstallationIsland';
---

<BaseLayout
  title="Dryer Installation Ocean Springs MS | Sudsy Co."
  description="Free dryer installation in Ocean Springs, MS with every Sudsy Co. rental. Electric and gas-compatible. We deliver, connect, and vent your dryer. Call (228) 338-3455."
>
  <h1 class="sr-only">Dryer Installation in Ocean Springs, MS</h1>
  <!-- SEO content for crawlers -->
  <article class="sr-only" aria-hidden="true">
    <p>Sudsy Co. provides free dryer installation in Ocean Springs, MS and across the Mississippi Gulf Coast. When you rent a dryer from us, we deliver it to your home, connect it to your electrical outlet or gas line, attach the vent hose, and test everything before we leave. Installation is included with every rental at no extra charge.</p>
    <p>We install electric dryers (standard 240V outlets) throughout our service area. If you have a gas dryer hookup, let us know when scheduling and we'll confirm compatibility. Our service area includes Ocean Springs, Biloxi, Gulfport, D'Iberville, Pascagoula, Gautier, Long Beach, Pass Christian, and Moss Point.</p>
    <p>Dryer installation includes: delivery to your location, connecting to your power source, attaching the exhaust vent hose, leveling the machine, and running a test cycle. We bring standard vent hoses and can handle most common setups.</p>
    <p>Call (228) 338-3455 to schedule dryer installation with your rental. Most installations are completed within 24-48 hours.</p>
  </article>
  <DryerInstallationIsland client:only="react" />
</BaseLayout>
