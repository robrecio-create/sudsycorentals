---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/astro/TopBar.astro';
import Header from '../../components/astro/Header.astro';
import Footer from '../../components/astro/Footer.astro';
import FloatingButtons from '../../components/astro/FloatingButtons.astro';
import { locations } from '../../data/locationData';

export function getStaticPaths() {
  return Object.keys(locations).map((city) => ({
    params: { city },
    props: { location: locations[city] },
  }));
}

const { location } = Astro.props;

const title = `Washer and Dryer Rental ${location.name} MS | Sudsy Co. Rentals`;
const description = `Rent a washer and dryer in ${location.name}, MS starting at $59.99/mo. Free next-day delivery, free installation, no credit check. Locally owned. Call (228) 338-3455.`;
const canonical = `https://www.sudsycorentals.com/washer-dryer-rental/${location.slug}`;

const pricing = [
  { label: "Washer Only", price: "$39.99/mo" },
  { label: "Washer & Dryer Set", price: "$59.99/mo" },
  { label: "Dryer Only", price: "$29.99/mo" },
];

const otherCities = Object.values(locations).filter((l) => l.slug !== location.slug);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Washer and Dryer Rental in ${location.name}, MS`,
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://sudsycorentals.com/#localbusiness",
    "name": "Sudsy Co. Rentals",
    "telephone": "+1-228-338-3455",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1302 Fort St",
      "addressLocality": "Ocean Springs",
      "addressRegion": "MS",
      "postalCode": "39564",
      "addressCountry": "US"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": location.name,
    "containedInPlace": { "@type": "State", "name": "Mississippi" }
  },
  "offers": {
    "@type": "Offer",
    "price": "59.99",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "59.99",
      "priceCurrency": "USD",
      "unitText": "month"
    }
  },
  "url": canonical
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sudsycorentals.com" },
    { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://www.sudsycorentals.com/areas-we-serve" },
    { "@type": "ListItem", "position": 3, "name": location.name, "item": `https://www.sudsycorentals.com/locations/${location.slug}` },
    { "@type": "ListItem", "position": 4, "name": "Washer & Dryer Rental" }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  geoRegion="US-MS"
  geoPlacename={`${location.name}, Mississippi`}
  geoPosition={`${location.coordinates.lat};${location.coordinates.lng}`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  <meta name="ICBM" content={`${location.coordinates.lat}, ${location.coordinates.lng}`} slot="head" />

  <div class="min-h-screen bg-background">
    <TopBar />
    <Header />

    <main>
      <!-- Hero Section -->
      <section class="hero-gradient pt-0 pb-16 md:pb-24 relative overflow-hidden">
        <nav aria-label="Breadcrumb" class="container mx-auto px-4 py-3">
          <ol class="flex items-center gap-2 text-sm text-primary-foreground/70">
            <li>
              <a href="/" class="flex items-center gap-1 hover:text-primary-foreground transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span class="sr-only">Home</span>
              </a>
            </li>
            <li class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              <a href="/areas-we-serve" class="hover:text-primary-foreground transition-colors">Locations</a>
            </li>
            <li class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              <a href={`/locations/${location.slug}`} class="hover:text-primary-foreground transition-colors">{location.name}</a>
            </li>
            <li class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              <span class="text-primary-foreground font-medium">Washer & Dryer Rental</span>
            </li>
          </ol>
        </nav>

        <div class="absolute top-0 left-0 w-72 h-72 bg-white/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>

        <div class="container mx-auto px-4 relative z-10">
          <div class="text-center max-w-3xl mx-auto">
            <div class="flex items-center justify-center gap-2 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-foreground/80"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <span class="text-primary-foreground/80 font-medium">Serving {location.name}, Mississippi</span>
            </div>

            <h1 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-primary-foreground mb-6">
              Washer & Dryer Rental in {location.name}, MS
            </h1>

            <p class="text-lg md:text-xl text-primary-foreground/90 mb-8 leading-relaxed">
              Skip the laundromat for good. Sudsy Co. delivers and installs a washer and dryer rental right to your home in {location.name} — starting at $59.99/mo with free next-day delivery and no credit check.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:+12283383455" class="inline-flex items-center justify-center gap-2 bg-white/10 border-2 border-white text-primary-foreground hover:bg-white hover:text-primary font-semibold text-lg px-8 h-11 rounded-md transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                (228) 338-3455
              </a>
              <a href="/#pricing" class="inline-flex items-center justify-center bg-white text-primary hover:bg-white/90 font-semibold text-lg px-8 h-11 rounded-md transition-colors">
                Rent Online
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Pricing Section -->
      <section class="py-16 bg-background">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-foreground mb-4">
              Washer & Dryer Rental Pricing in {location.name}
            </h2>
            <p class="text-muted-foreground max-w-2xl mx-auto">
              Simple, transparent monthly rates. No hidden fees, no credit check, no long-term commitment.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto">
            {pricing.map((plan, index) => (
              <div class={`h-full text-center rounded-lg border transition-colors ${index === 1 ? "border-primary ring-1 ring-primary" : "border-border/50 hover:border-primary/30"}`}>
                <div class="p-6">
                  <p class="font-semibold text-foreground mb-2">{plan.label}</p>
                  <p class="text-2xl font-bold text-primary">{plan.price}</p>
                  {index === 1 && (
                    <span class="inline-block mt-2 bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full">
                      Most Popular
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="py-16 bg-muted/30">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-foreground mb-4">
              Why {location.name} Residents Choose Sudsy Co.
            </h2>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <!-- Truck icon - Free Next-Day Delivery -->
            <div class="text-center">
              <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
              </div>
              <h3 class="font-display font-semibold text-xl text-foreground mb-2">Free Next-Day Delivery</h3>
              <p class="text-muted-foreground">We deliver and install — no extra charge.</p>
            </div>
            <!-- Shield icon - No Credit Check -->
            <div class="text-center">
              <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
              </div>
              <h3 class="font-display font-semibold text-xl text-foreground mb-2">No Credit Check</h3>
              <p class="text-muted-foreground">Everyone qualifies. Simple, fast approval.</p>
            </div>
            <!-- Clock icon - Month-to-Month -->
            <div class="text-center">
              <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <h3 class="font-display font-semibold text-xl text-foreground mb-2">Month-to-Month</h3>
              <p class="text-muted-foreground">No long-term contracts. Cancel anytime.</p>
            </div>
          </div>

          <!-- Location highlights as checkmarks -->
          <div class="grid md:grid-cols-2 gap-4 mt-12 max-w-2xl mx-auto">
            {location.highlights.map((h: string) => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </div>
                <span class="text-foreground font-medium">{h}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- How It Works Section -->
      <section class="py-16 bg-background">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-foreground mb-4">
              How to Get a Washer & Dryer Rental in {location.name}
            </h2>
          </div>

          <div class="grid md:grid-cols-3 gap-8 max-w-3xl mx-auto">
            <div class="text-center">
              <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center mx-auto mb-4">
                <span class="text-primary-foreground font-bold text-lg">1</span>
              </div>
              <h3 class="font-semibold text-foreground mb-2">Choose Your Package</h3>
              <p class="text-muted-foreground">Pick washer only, dryer only, or the full set. Rent online or call us.</p>
            </div>
            <div class="text-center">
              <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center mx-auto mb-4">
                <span class="text-primary-foreground font-bold text-lg">2</span>
              </div>
              <h3 class="font-semibold text-foreground mb-2">We Deliver & Install</h3>
              <p class="text-muted-foreground">We schedule delivery to your {location.name} address — next day in most cases.</p>
            </div>
            <div class="text-center">
              <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center mx-auto mb-4">
                <span class="text-primary-foreground font-bold text-lg">3</span>
              </div>
              <h3 class="font-semibold text-foreground mb-2">Enjoy Clean Laundry</h3>
              <p class="text-muted-foreground">We handle all repairs for free. Cancel any time with one phone call.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Nearby Cities Section -->
      <section class="py-16 bg-muted/30">
        <div class="container mx-auto px-4">
          <div class="text-center">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-foreground mb-4">
              Also Serving Nearby Mississippi Gulf Coast Cities
            </h2>
            <div class="flex flex-wrap justify-center gap-3 mt-6">
              {otherCities.map((c) => (
                <a
                  href={`/washer-dryer-rental/${c.slug}`}
                  class="inline-flex items-center gap-2 bg-background px-4 py-2 rounded-full text-foreground font-medium hover:bg-primary/10 border border-border hover:border-primary/30 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--primary))" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Washer & Dryer Rental {c.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="py-16 hero-gradient relative overflow-hidden">
        <div class="absolute top-0 left-0 w-72 h-72 bg-white/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
        <div class="container mx-auto px-4 relative z-10">
          <div class="text-center max-w-2xl mx-auto">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-primary-foreground mb-4">
              Ready to Rent a Washer & Dryer in {location.name}?
            </h2>
            <p class="text-primary-foreground/90 mb-8">
              Free delivery, free installation, no credit check. Get started today.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:+12283383455" class="inline-flex items-center justify-center gap-2 bg-white/10 border-2 border-white text-primary-foreground hover:bg-white hover:text-primary font-semibold text-lg px-8 h-11 rounded-md transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                (228) 338-3455
              </a>
              <a href="/#pricing" class="inline-flex items-center justify-center bg-white text-primary hover:bg-white/90 font-semibold text-lg px-8 h-11 rounded-md transition-colors">
                Rent Online
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
    <FloatingButtons />
  </div>
</BaseLayout>
