{
  "framework": "astro",
  "crons": [
    {
      "path": "/api/cron/review-requests",
      "schedule": "0 15 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/pricing",
      "destination": "/#pricing",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/services/",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/services/",
      "permanent": true
    },
    {
      "source": "/faq",
      "destination": "/resources/",
      "permanent": true
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "sudsycorentals.com" }],
      "destination": "https://www.sudsycorentals.com/:path",
      "permanent": true
    }
  ],
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
